# Optional: enable real DeepSeek chat calls.
# The demo works without this key and falls back to local mock AI answers.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Used to encrypt API keys saved from the admin model settings page.
# Use a stable random value of at least 32 characters and never expose it to the browser.
SECRET_ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret

# Admin protection. Change both values before production deployment.
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_EMAIL=admin@example.com
ADMIN_SESSION_TOKEN=replace-with-a-long-random-secret

# Required in production. Local development can run without it, but persistence is disabled.
DATABASE_URL=postgresql://user:password@localhost:5432/personal_ai
DATABASE_MAX_CONNECTIONS=10
DATABASE_SSL=false

# Media storage. "database" keeps image bytes in PostgreSQL; "s3" is recommended for large production libraries.
STORAGE_DRIVER=database
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
