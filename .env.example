# Optional: enable real DeepSeek chat calls.
# The demo works without this key and falls back to local mock AI answers.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Admin protection. Change both values before production deployment.
ADMIN_PASSWORD=demo123456
ADMIN_SESSION_TOKEN=replace-with-a-long-random-secret

# Optional: later PostgreSQL / pgvector connection.
DATABASE_URL=postgresql://user:password@localhost:5432/personal_ai
